{
  "//": "======================================================",
  "// ": "Claude Code セキュリティ設定 (プロジェクトレベル)",
  "//  ": "======================================================",

  "// 1": "--- サンドボックス：有効化 + 脱出口封鎖 ---",
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,

    "// filesystem": "機密ファイルのBash経由アクセスもブロック",
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.aws/config",
        "~/.ssh",
        "~/.gnupg",
        "~/.config/gh/hosts.yml",
        "~/.netrc"
      ]
    },

    "// network": "業務に必要なドメインのみ許可（ホワイトリスト方式）",
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    }
  },

  "// 2": "--- パーミッション：denyは最優先。Always allowでも上書き不可 ---",
  "permissions": {
    "// allow": "安全な定型コマンドを事前許可（プロンプト削減）",
    "allow": [
      "Bash(npx vite build)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git push)",
      "Bash(git push -u origin *)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(grep *)",
      "Bash(find . *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f *)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(git branch -D *)",
      "Bash(rm -rf *)",
      "Bash(rm -r /*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(sudo *)",
      "Bash(eval *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)"
    ]
  },

  "// 3": "--- ステータスライン：ブランチ名とコンテキスト残量を表示 ---",
  "statusLine": {
    "type": "command",
    "command": "echo \"$(git branch --show-current 2>/dev/null) | ctx ${CLAUDE_CONTEXT_USAGE_PERCENT:-?}%\""
  },

  "// 4": "--- フック：危険パターンを実行前に検出 ---",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-command.sh"
          }
        ]
      }
    ]
  }
}
